.card {
  background: rgba(15, 23, 42, 0.78);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 50rpx rgba(2, 6, 23, 0.22);
  backdrop-filter: blur(18px);
}

.card--compact {
  padding: 20rpx;
}

.card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
}

.card__extra {
  font-size: 24rpx;
  color: #94a3b8;
}

.card__body {
  color: #cbd5e1;
}
