.stats-chart {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stats-chart__head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.stats-chart__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #f8fafc;
}

.stats-chart__subtitle {
  font-size: 22rpx;
  color: #94a3b8;
}

.stats-chart__body {
  width: 100%;
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(2, 6, 23, 0.26);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.stats-chart__canvas {
  width: 100%;
  height: 100%;
}
