.button {
  min-width: 160rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 22rpx;
  font-size: 26rpx;
  padding: 0 24rpx;
  box-shadow: 0 16rpx 32rpx rgba(2, 6, 23, 0.22);
}

.button--block {
  width: 100%;
}

.button--primary {
  color: #00111c;
  background: linear-gradient(135deg, #8be1ff 0%, #38bdf8 55%, #0ea5e9 100%);
}

.button--ghost {
  color: #e2e8f0;
  background: rgba(148, 163, 184, 0.12);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.button--danger {
  color: #fff;
  background: linear-gradient(135deg, #fb7185 0%, #f43f5e 100%);
}

.button--ghost.button--disabled,
.button--primary.button--disabled,
.button--danger.button--disabled {
  border-color: transparent;
}

.button--disabled {
  opacity: 0.45;
}
