.bill {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 0;
}

.bill__icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  color: #fff;
}

.bill__icon--orange {
  background: linear-gradient(135deg, #f97316 0%, #fb923c 100%);
}

.bill__icon--blue {
  background: linear-gradient(135deg, #2563eb 0%, #38bdf8 100%);
}

.bill__icon--violet {
  background: linear-gradient(135deg, #7c3aed 0%, #a78bfa 100%);
}

.bill__icon--emerald {
  background: linear-gradient(135deg, #059669 0%, #34d399 100%);
}

.bill__icon--pink {
  background: linear-gradient(135deg, #db2777 0%, #fb7185 100%);
}

.bill__icon--cyan {
  background: linear-gradient(135deg, #0891b2 0%, #22d3ee 100%);
}

.bill__icon--amber {
  background: linear-gradient(135deg, #d97706 0%, #fbbf24 100%);
}

.bill__icon--green {
  background: linear-gradient(135deg, #16a34a 0%, #4ade80 100%);
}

.bill__icon--slate {
  background: linear-gradient(135deg, #475569 0%, #94a3b8 100%);
}

.bill__icon--gray {
  background: linear-gradient(135deg, #334155 0%, #64748b 100%);
}

.bill__icon--expense {
  background: linear-gradient(135deg, #f43f5e 0%, #fb7185 100%);
}

.bill__icon--income {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
}

.bill__body {
  flex: 1;
  min-width: 0;
}

.bill__title {
  font-size: 28rpx;
  color: #f8fafc;
}

.bill__merchant {
  color: #94a3b8;
}

.bill__meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.bill__right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.bill__amount {
  font-size: 28rpx;
  font-weight: 600;
}

.bill__amount--expense {
  color: #fda4af;
}

.bill__amount--income {
  color: #86efac;
}

.bill__actions {
  display: flex;
  gap: 10rpx;
}

.bill__action {
  font-size: 20rpx;
  color: #cbd5e1;
  padding: 4rpx 12rpx;
  background: rgba(148, 163, 184, 0.12);
  border-radius: 999rpx;
}

.bill__action--danger {
  color: #fecdd3;
}
