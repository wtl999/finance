.bill {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 10rpx 0;
}

.bill__icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
  box-shadow: 0 10rpx 20rpx rgba(2, 6, 23, 0.2);
}

.bill__icon--orange { background: linear-gradient(135deg, #f97316 0%, #fb923c 100%); }
.bill__icon--blue { background: linear-gradient(135deg, #2563eb 0%, #38bdf8 100%); }
.bill__icon--violet { background: linear-gradient(135deg, #7c3aed 0%, #a78bfa 100%); }
.bill__icon--emerald { background: linear-gradient(135deg, #059669 0%, #34d399 100%); }
.bill__icon--pink { background: linear-gradient(135deg, #db2777 0%, #fb7185 100%); }
.bill__icon--cyan { background: linear-gradient(135deg, #0891b2 0%, #22d3ee 100%); }
.bill__icon--amber { background: linear-gradient(135deg, #d97706 0%, #fbbf24 100%); }
.bill__icon--green { background: linear-gradient(135deg, #16a34a 0%, #4ade80 100%); }
.bill__icon--slate { background: linear-gradient(135deg, #475569 0%, #94a3b8 100%); }
.bill__icon--gray { background: linear-gradient(135deg, #334155 0%, #64748b 100%); }
.bill__icon--expense { background: linear-gradient(135deg, #f43f5e 0%, #fb7185 100%); }
.bill__icon--income { background: linear-gradient(135deg, #10b981 0%, #34d399 100%); }

.bill__content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.bill__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.bill__title {
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #f8fafc;
  min-width: 0;
}

.bill__amount {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 700;
  white-space: nowrap;
  letter-spacing: 0.2rpx;
}

.bill__amount--expense {
  color: #fda4af;
}

.bill__amount--income {
  color: #86efac;
}

.bill__meta {
  font-size: 22rpx;
  line-height: 1.55;
  color: #94a3b8;
  word-break: break-all;
}

.bill__merchant {
  color: #cbd5e1;
}

.bill__actions {
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
}

.bill__action {
  min-width: 128rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #e2e8f0;
  background: rgba(148, 163, 184, 0.12);
  line-height: 48rpx;
}

.bill__action--danger {
  color: #fecdd3;
  background: rgba(244, 63, 94, 0.12);
}
