.profile-summary {
  padding-top: 4rpx;
}

.profile-summary__card {
  display: flex;
  gap: 18rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.94), rgba(15, 23, 42, 0.72));
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.26);
}

.profile-summary__avatar {
  width: 104rpx;
  height: 104rpx;
  flex-shrink: 0;
  border-radius: 30rpx;
  overflow: hidden;
  background: rgba(148, 163, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-summary__avatar-img {
  width: 100%;
  height: 100%;
}

.profile-summary__avatar-fallback {
  font-size: 34rpx;
  font-weight: 700;
  color: #7dd3fc;
}

.profile-summary__body {
  flex: 1;
  min-width: 0;
}

.profile-summary__name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.profile-summary__name {
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
}

.profile-summary__tag {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.16);
  color: #7dd3fc;
  font-size: 20rpx;
}

.profile-summary__sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #cbd5e1;
  line-height: 1.5;
}

.profile-summary__meta {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.profile-summary__chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.12);
  color: #94a3b8;
  font-size: 20rpx;
}
