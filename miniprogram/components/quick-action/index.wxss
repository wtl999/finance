.action {
  border-radius: 24rpx;
  padding: 24rpx;
  min-height: 132rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: #fff;
  box-shadow: 0 18rpx 40rpx rgba(2, 6, 23, 0.24);
}

.action--cyan {
  background: linear-gradient(135deg, #0891b2 0%, #0ea5e9 100%);
}

.action--violet {
  background: linear-gradient(135deg, #1d4ed8 0%, #4f46e5 100%);
}

.action--emerald {
  background: linear-gradient(135deg, #059669 0%, #10b981 100%);
}

.action--rose {
  background: linear-gradient(135deg, #be123c 0%, #f43f5e 100%);
}

.action__label {
  font-size: 28rpx;
  font-weight: 600;
}

.action__hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.82;
}
