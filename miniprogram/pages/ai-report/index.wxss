.report-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background:
    radial-gradient(circle at top, rgba(56, 189, 248, 0.16), transparent 36%),
    linear-gradient(180deg, #09111f 0%, #0b1220 48%, #070d18 100%);
  color: #e2e8f0;
}

.hero {
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(15, 23, 42, 0.72));
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 24rpx 60rpx rgba(0, 0, 0, 0.28);
}

.hero__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #f8fafc;
}

.hero__subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.hero__meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 18rpx;
}

.hero__badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.16);
  color: #7dd3fc;
  font-size: 22rpx;
}

.hero__range {
  font-size: 22rpx;
  color: #94a3b8;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.segmented {
  display: flex;
  padding: 6rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.segmented__item {
  min-width: 88rpx;
  padding: 14rpx 20rpx;
  border-radius: 14rpx;
  text-align: center;
  font-size: 24rpx;
  color: #94a3b8;
}

.segmented__item--active {
  background: linear-gradient(135deg, #38bdf8, #0ea5e9);
  color: #ffffff;
}

.toolbar__picker {
  min-width: 180rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(15, 23, 42, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  color: #cbd5e1;
}

.overview {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.overview__text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #e2e8f0;
}

.overview__text--muted {
  color: #94a3b8;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.list__item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.list__item--alert {
  border-color: rgba(251, 113, 133, 0.2);
}

.list__main {
  flex: 1;
  min-width: 0;
}

.list__title {
  font-size: 26rpx;
  color: #f8fafc;
}

.list__desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.list__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.list__amount {
  font-size: 26rpx;
  font-weight: 700;
  color: #e2e8f0;
}

.list__amount--up {
  color: #fb7185;
}

.list__amount--down {
  color: #34d399;
}

.list__tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.14);
  color: #cbd5e1;
  font-size: 20rpx;
}

.list__tag--high {
  background: rgba(251, 113, 133, 0.16);
  color: #fda4af;
}

.list__tag--medium {
  background: rgba(245, 158, 11, 0.16);
  color: #fcd34d;
}

.list__tag--low {
  background: rgba(52, 211, 153, 0.16);
  color: #86efac;
}

.frequency {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.frequency__item {
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.frequency__head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.frequency__label {
  font-size: 26rpx;
  color: #f8fafc;
}

.frequency__value {
  font-size: 24rpx;
  font-weight: 700;
  color: #7dd3fc;
}

.frequency__desc,
.frequency__hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.actions__item {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(15, 23, 42, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  color: #e2e8f0;
  line-height: 1.6;
  font-size: 24rpx;
}
