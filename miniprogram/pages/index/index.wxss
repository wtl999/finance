.index-page {
  padding-top: 16rpx;
}

.hero {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.96) 0%, rgba(8, 15, 31, 0.92) 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  box-shadow: 0 24rpx 48rpx rgba(2, 6, 23, 0.3);
  animation: fadeUp 280ms ease-out both;
}

.hero__top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.hero__hello {
  font-size: 38rpx;
  font-weight: 700;
  color: #f8fafc;
}

.hero__sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.hero__avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: rgba(148, 163, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero__avatar-img {
  width: 100%;
  height: 100%;
}

.hero__avatar-fallback {
  font-size: 32rpx;
  font-weight: 700;
  color: #7dd3fc;
}

.spacer {
  height: 24rpx;
}

.ai-box__input {
  width: 100%;
  min-height: 170rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(2, 6, 23, 0.4);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  color: #f8fafc;
  font-size: 26rpx;
  transition: border-color 180ms ease, transform 180ms ease;
}

.ai-box__input:focus {
  border-color: rgba(56, 189, 248, 0.55);
  transform: translateY(-1rpx);
}

.ai-box__actions {
  margin-top: 18rpx;
  display: flex;
  gap: 14rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action-grid,
.report-json,
.spacer {
  animation: fadeUp 280ms ease-out both;
}

.report-json {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.report-json__row {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(148, 163, 184, 0.08);
  color: #e2e8f0;
  font-size: 24rpx;
  line-height: 1.6;
}

.ocr {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.ocr__sources {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.ocr__source {
  padding: 12rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(148, 163, 184, 0.08);
  color: #cbd5e1;
  font-size: 22rpx;
}

.ocr__source.is-active {
  background: linear-gradient(135deg, #0ea5e9 0%, #38bdf8 100%);
  color: #00111c;
  font-weight: 600;
}

.ocr__actions {
  display: flex;
  gap: 14rpx;
}

.ocr-result {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(2, 6, 23, 0.36);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
}

.ocr-result__head {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  align-items: center;
}

.ocr-result__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.ocr-result__tag {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.12);
  color: #7dd3fc;
  font-size: 20rpx;
}

.ocr-result__line {
  font-size: 22rpx;
  line-height: 1.6;
  color: #cbd5e1;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
