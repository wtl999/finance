.stats-page {
  padding-top: 16rpx;
}

.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.topbar__picker {
  min-width: 220rpx;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: rgba(2, 6, 23, 0.4);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  display: flex;
  align-items: center;
  color: #f8fafc;
}

.spacer {
  height: 24rpx;
}

.chart-stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  animation: fadeUp 280ms ease-out both;
}

.insight {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.insight__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.insight__body {
  font-size: 24rpx;
  line-height: 1.7;
  color: #cbd5e1;
}

.insight__tag {
  display: inline-flex;
  width: fit-content;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.12);
  color: #7dd3fc;
  font-size: 22rpx;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
