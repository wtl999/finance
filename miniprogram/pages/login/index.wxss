.login-page {
  min-height: 100vh;
  background: #fff;
  padding: 0 48rpx 56rpx;
  box-sizing: border-box;
}

.login-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 120rpx;
}

.hero__logo {
  width: 212rpx;
  height: 212rpx;
  border-radius: 48rpx;
  background: #ffd64d;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 24rpx 48rpx rgba(0, 0, 0, 0.06);
}

.hero__symbol {
  font-size: 128rpx;
  font-weight: 700;
  color: #2f2f2f;
  line-height: 1;
}

.hero__title {
  margin-top: 44rpx;
  font-size: 64rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  color: #333;
}

.hero__desc {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #9a9a9a;
  text-align: center;
}

.login-card {
  width: 100%;
  margin-top: auto;
  padding-bottom: 64rpx;
}

.wechat-btn,
.password-btn {
  width: 100%;
  height: 108rpx;
  border-radius: 28rpx;
  font-size: 34rpx;
  line-height: 108rpx;
  text-align: center;
  border: none;
  margin: 0;
}

.wechat-btn {
  background: #ffd64d;
  color: #303030;
  box-shadow: 0 16rpx 32rpx rgba(255, 214, 77, 0.28);
}

.password-btn {
  margin-top: 24rpx;
  background: #f4f4f4;
  color: #333;
}

.wechat-btn::after,
.password-btn::after {
  border: none;
}

.switch-row {
  padding: 28rpx 0 16rpx;
  text-align: center;
}

.switch-row__text {
  font-size: 28rpx;
  color: #95a1aa;
}

.password-panel {
  margin-top: 8rpx;
  padding: 28rpx 0 0;
}

.field {
  margin-top: 18rpx;
}

.field__label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #666;
}

.field__input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: #f7f7f7;
  color: #222;
  font-size: 30rpx;
  box-sizing: border-box;
}

.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 34rpx;
}

.agreement__icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #f2f2f2;
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.agreement__icon--on {
  background: #ffd64d;
  color: #333;
}

.agreement__text {
  font-size: 22rpx;
  color: #9a9a9a;
}
