.login-page {
  min-height: 100vh;
  padding: 48rpx 28rpx 56rpx;
  background:
    linear-gradient(180deg, #07111f 0%, #091523 42%, #050913 100%);
}

.shell {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.brand {
  padding: 12rpx 4rpx 4rpx;
}

.brand__eyebrow {
  font-size: 22rpx;
  letter-spacing: 1rpx;
  color: #7dd3fc;
}

.brand__title {
  margin-top: 12rpx;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.15;
  color: #f8fafc;
}

.brand__desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #94a3b8;
}

.profile-panel {
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.86);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.profile-panel__avatar {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.avatar-picker {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  border-radius: 50%;
  overflow: hidden;
  background: transparent;
}

.avatar-picker::after {
  border: 0;
}

.avatar-picker__img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-picker__mask {
  position: absolute;
  inset: auto 0 0;
  padding: 12rpx 0;
  background: rgba(15, 23, 42, 0.72);
  color: #e2e8f0;
  font-size: 22rpx;
  text-align: center;
}

.profile-panel__fields {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.field__label {
  font-size: 24rpx;
  color: #94a3b8;
}

.field__input {
  height: 84rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: rgba(2, 6, 23, 0.72);
  color: #f8fafc;
  font-size: 28rpx;
  box-sizing: border-box;
}

.field__phone {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 84rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: rgba(2, 6, 23, 0.72);
  box-sizing: border-box;
}

.field__value {
  flex: 1;
  min-width: 0;
  color: #f8fafc;
  font-size: 28rpx;
}

.field__button {
  flex: 0 0 auto;
  margin: 0;
  padding: 0 18rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 14rpx;
  background: rgba(125, 211, 252, 0.14);
  color: #7dd3fc;
  font-size: 24rpx;
}

.field__button::after {
  border: 0;
}

.profile-panel__actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 26rpx;
}

.hint-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hint-item {
  padding-left: 18rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}
