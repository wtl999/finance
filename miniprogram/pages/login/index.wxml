<view class="page login-page safe-bottom">
  <view class="hero">
    <view class="hero__badge">CloudBase · AI Ledger</view>
    <view class="hero__title">{{appName}}</view>
    <view class="hero__desc">登录后自动绑定 openid，开启账单记录、统计和 AI 分析。</view>
  </view>

  <t-card title="开始使用" extra="MVP">
    <view class="login-card">
      <view class="login-card__line">首次登录会自动创建 users collection</view>
      <view class="login-card__line">头像与昵称由微信授权获取</view>
      <view class="login-card__line">登录状态本地持久化</view>
      <view class="login-card__actions">
        <t-button block loading="{{loading}}" bindtap="handleLogin">微信授权登录</t-button>
      </view>
    </view>
  </t-card>

  <t-section title="项目约束" extra="README">
    <view class="rules">
      <view class="rules__item">原生小程序</view>
      <view class="rules__item">JavaScript</view>
      <view class="rules__item">微信云开发</view>
      <view class="rules__item">模块化结构</view>
    </view>
  </t-section>
</view>
