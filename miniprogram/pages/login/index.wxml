<view class="login-page safe-bottom">
  <view class="login-shell">
    <view class="hero">
      <view class="hero__logo">
        <text class="hero__symbol">¥</text>
      </view>
      <view class="hero__title">{{appName}}</view>
      <view class="hero__desc">微信授权后自动绑定 openid，随后补全手机号和密码，登录永久有效。</view>
    </view>

    <view class="login-card">
      <button class="wechat-btn" loading="{{loading}}" bindtap="handleWechatLogin">
        微信登录
      </button>

      <view class="switch-row" bindtap="toggleMode">
        <text class="switch-row__text">更多登录方式</text>
      </view>

      <view wx:if="{{loginMode === 'password'}}" class="password-panel">
        <view class="field">
          <text class="field__label">手机号</text>
          <input class="field__input" type="number" placeholder="输入手机号" value="{{profile.phoneNumber}}" bindinput="handlePhoneInput" />
        </view>
        <view class="field">
          <text class="field__label">密码</text>
          <input class="field__input" password placeholder="输入密码" value="{{profile.password}}" bindinput="handlePasswordInput" />
        </view>
        <button class="password-btn" loading="{{loading}}" bindtap="handlePasswordLogin">账号密码登录</button>
      </view>

      <view class="agreement" bindtap="toggleAgree">
        <view class="agreement__icon {{agree ? 'agreement__icon--on' : ''}}">{{agree ? '✓' : ''}}</view>
        <text class="agreement__text">已阅读并同意《用户协议》和《隐私协议》</text>
      </view>
    </view>
  </view>
</view>
