.categories-page {
  padding-top: 16rpx;
}

.intro {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.intro__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #f8fafc;
}

.intro__desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.type-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.type-tabs__item {
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(148, 163, 184, 0.08);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.type-tabs__item.is-active {
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.9) 0%, rgba(56, 189, 248, 0.9) 100%);
  border-color: rgba(125, 211, 252, 0.4);
}

.type-tabs__label {
  font-size: 28rpx;
  font-weight: 700;
  color: #f8fafc;
}

.type-tabs__desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: rgba(226, 232, 240, 0.84);
}

.spacer {
  height: 24rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.category-list__item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx;
  border-radius: 20rpx;
  background: rgba(15, 23, 42, 0.72);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
}

.category-list__input,
.add-box__input {
  flex: 1;
  min-width: 0;
  min-height: 74rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: rgba(2, 6, 23, 0.42);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  color: #f8fafc;
  font-size: 26rpx;
}

.category-list__tone {
  min-width: 88rpx;
  padding: 10rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(56, 189, 248, 0.12);
  color: #7dd3fc;
  font-size: 20rpx;
  text-align: center;
}

.category-list__delete {
  color: #fda4af;
  font-size: 22rpx;
}

.add-box {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.add-box__actions {
  display: flex;
  gap: 12rpx;
}

.add-box__save {
  margin-top: 4rpx;
}
