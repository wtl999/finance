.bills-page {
  padding-top: 16rpx;
}

.filter {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.filter__picker {
  width: 100%;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: rgba(2, 6, 23, 0.4);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  color: #f8fafc;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}

.filter__types {
  display: flex;
  gap: 12rpx;
}

.filter__type {
  padding: 12rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(148, 163, 184, 0.08);
  color: #cbd5e1;
  font-size: 22rpx;
}

.filter__type.is-active {
  background: linear-gradient(135deg, #0ea5e9 0%, #38bdf8 100%);
  color: #00111c;
  font-weight: 600;
}

.spacer {
  height: 24rpx;
}

.timeline {
  position: relative;
  padding-left: 18rpx;
}

.timeline__group {
  position: relative;
  margin-bottom: 18rpx;
  padding-left: 20rpx;
}

.timeline__group::before {
  content: '';
  position: absolute;
  left: 18rpx;
  top: 56rpx;
  bottom: -12rpx;
  width: 2rpx;
  background: rgba(148, 163, 184, 0.18);
}

.timeline__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  color: #cbd5e1;
}

.timeline__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #38bdf8 0%, #7dd3fc 100%);
  box-shadow: 0 0 0 6rpx rgba(56, 189, 248, 0.12);
}

.timeline__date {
  font-size: 28rpx;
  font-weight: 600;
  color: #f8fafc;
}

.timeline__summary {
  font-size: 22rpx;
  color: #94a3b8;
}

.timeline__body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.timeline__item {
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.76);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  box-shadow: 0 16rpx 30rpx rgba(2, 6, 23, 0.18);
}

.load-more {
  padding: 24rpx 0 8rpx;
  text-align: center;
}

.load-more__text {
  font-size: 22rpx;
  color: #94a3b8;
}

.bottom-actions {
  margin-top: 24rpx;
}

.editor-mask {
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.56);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.editor-sheet {
  width: 100%;
  max-height: 90vh;
  overflow: auto;
  padding: 24rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #0b1220;
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
  box-shadow: 0 -16rpx 40rpx rgba(2, 6, 23, 0.4);
}

.editor-sheet__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.editor-sheet__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8fafc;
}

.editor-sheet__close {
  font-size: 24rpx;
  color: #94a3b8;
}
