page {
  background: #0b1220;
  color: #e5eefb;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

view,
text,
input,
textarea,
picker,
scroll-view,
swiper {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  border: 0;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
